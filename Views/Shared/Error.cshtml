@* ── Shared/Error.cshtml ── *@
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section style="min-height:60vh;display:flex;align-items:center;background:var(--light-gray);">
    <div class="container text-center py-5">
        <div style="font-size:5rem;">⚠️</div>
        <h1 class="fw-bold mt-3">Something Went Wrong</h1>
        <p class="text-muted mt-2 mb-4">An unexpected error occurred. Please try again.</p>
        <a asp-controller="Home" asp-action="Index" class="btn-primary-custom">
            <i class="fas fa-home me-2"></i>Back to Home
        </a>
    </div>
</section>
