@{
    ViewData["Title"] = "Check Your Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section style="background:var(--light-gray);min-height:calc(100vh - 72px);" class="d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="form-card text-center">
                    <div style="width:80px;height:80px;background:#dcfce7;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 1.5rem;">
                        ✉️
                    </div>
                    <h2 class="fw-bold mb-2">Check Your Email</h2>
                    <p class="text-muted mb-4">
                        If an account exists with that email address, we've sent a password reset link.
                        Please check your inbox (and spam folder).
                    </p>

                    <div class="alert" style="background:#f0f9ff;border:1.5px solid #bae6fd;border-radius:10px;font-size:.88rem;color:#0369a1;">
                        <i class="fas fa-clock me-2"></i>
                        The reset link will expire in <strong>1 hour</strong>.
                    </div>

                    <hr class="my-4"/>
                    <a asp-action="ForgotPassword" class="btn btn-outline-primary rounded-pill px-4 me-2">
                        Resend Email
                    </a>
                    <a asp-action="Login" class="btn btn-outline-secondary rounded-pill px-4">
                        Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
