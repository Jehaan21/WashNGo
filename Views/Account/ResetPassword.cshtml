@model WashNGo.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section style="background:var(--light-gray);min-height:calc(100vh - 72px);" class="d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="form-card">
                    <div class="text-center mb-4">
                        <div style="font-size:3rem;">🔒</div>
                        <h2 class="fw-bold mt-2 mb-1">Set New Password</h2>
                        <p class="text-muted" style="font-size:.93rem;">
                            Choose a strong password for your account.
                        </p>
                    </div>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Token"/>
                        <input type="hidden" asp-for="Email"/>

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">New Password</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                                <input asp-for="NewPassword" class="form-control" placeholder="Min 6 characters" id="newPwd"/>
                                <button type="button" class="input-group-text" onclick="togglePwd('newPwd', this)">
                                    <i class="fas fa-eye text-muted"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" id="confirmPwd"/>
                                <button type="button" class="input-group-text" onclick="togglePwd('confirmPwd', this)">
                                    <i class="fas fa-eye text-muted"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn-primary-custom w-100 justify-content-center py-3">
                            <i class="fas fa-check me-2"></i>Reset Password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
    function togglePwd(id, btn) {
        const inp  = document.getElementById(id);
        const icon = btn.querySelector('i');
        inp.type = inp.type === 'password' ? 'text' : 'password';
        icon.classList.toggle('fa-eye');
        icon.classList.toggle('fa-eye-slash');
    }
    </script>
}
