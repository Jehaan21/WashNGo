@model WashNGo.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Create Account – WashNGo</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
    --navy:#071739; --navy-2:#0d2150; --white:#fff; --gray:#F7F9FC;
    --accent:#1E90FF; --accent-dark:#1271d4; --text-muted:#64748b; --border:#e6eaf0;
    --danger:#ef4444; --warn:#f59e0b; --ok:#22c55e;
}
*{box-sizing:border-box;}
body{ font-family:'Inter',sans-serif; margin:0; background:var(--gray); }
.auth-wrap{ display:flex; min-height:100vh; }

/* LEFT (same illustration style, shorter) */
.auth-left{
    flex:.85; position:sticky; top:0; align-self:flex-start; height:100vh;
    background:linear-gradient(160deg,var(--navy) 0%,var(--navy-2) 55%,#143a7a 100%);
    display:flex; flex-direction:column; justify-content:space-between;
    padding:44px 48px; color:#fff; overflow:hidden;
}
.auth-left::before{
    content:''; position:absolute; width:560px; height:560px; border-radius:50%;
    background:radial-gradient(circle, rgba(30,144,255,.18), transparent 70%);
    top:-180px; right:-180px;
}
.brand{ display:flex; align-items:center; gap:10px; font-size:1.4rem; font-weight:800; position:relative; z-index:2;}
.brand span{ color:var(--accent); }
.brand .badge-n{ background:var(--accent); color:#fff; border-radius:8px; padding:2px 8px; }
.illu-zone{ position:relative; flex:1; display:flex; align-items:center; justify-content:center; z-index:2; }
.car-illu{ width:100%; max-width:340px; filter:drop-shadow(0 30px 60px rgba(0,0,0,.45)); animation:float 5s ease-in-out infinite; }
@@keyframes float{ 0%,100%{transform:translateY(0px);} 50%{transform:translateY(-12px);} }
.slogan-zone{ position:relative; z-index:2; }
.slogan-zone h1{ font-size:1.7rem; font-weight:800; line-height:1.3; margin:0 0 6px; }
.slogan-zone h1 span{ color:var(--accent); }
.slogan-zone p{ opacity:.75; font-size:.9rem; margin:0; }

/* RIGHT */
.auth-right{ flex:1.5; padding:48px 56px; display:flex; justify-content:center; }
.signup-card{
    width:100%; max-width:640px; background:rgba(255,255,255,.9);
    backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,.6);
    border-radius:24px; padding:44px 48px; box-shadow:0 20px 60px rgba(7,23,57,.08);
    animation:cardIn .5s ease;
}
@@keyframes cardIn{ from{opacity:0; transform:translateY(16px);} to{opacity:1; transform:translateY(0);} }

.sc-header h2{ font-weight:800; color:var(--navy); margin:0 0 4px; font-size:1.7rem; }
.sc-header p{ color:var(--text-muted); font-size:.93rem; margin-bottom:30px; }

.section-block{ margin-bottom:30px; }
.section-title{
    font-size:.78rem; font-weight:800; letter-spacing:1.2px; text-transform:uppercase;
    color:var(--accent); margin-bottom:16px; display:flex; align-items:center; gap:8px;
}
.section-title::after{ content:''; flex:1; height:1px; background:var(--border); }

.f-group{ margin-bottom:16px; }
.f-label{ font-weight:600; font-size:.84rem; color:var(--navy); margin-bottom:6px; display:block; }
.f-label .req{ color:var(--danger); }
.f-input, .f-select{
    width:100%; padding:12px 16px; border:1.5px solid var(--border);
    border-radius:12px; font-size:.9rem; background:#fff; transition:.2s;
}
.f-input:focus, .f-select:focus{ outline:none; border-color:var(--accent); box-shadow:0 0 0 4px rgba(30,144,255,.1); }
.f-input.is-invalid{ border-color:var(--danger); }
.err-msg{ color:var(--danger); font-size:.78rem; margin-top:4px; display:block; }
.f-input-wrap{ position:relative; }
.toggle-eye{ position:absolute; right:14px; top:50%; transform:translateY(-50%); background:none; border:none; color:#94a3b8; cursor:pointer; }

.row2{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.row3{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; }
@@media (max-width:560px){ .row2,.row3{ grid-template-columns:1fr; } }

/* Password requirements */
.pwd-reqs{ background:#f8fafc; border-radius:10px; padding:12px 14px; margin-top:8px; font-size:.78rem; }
.pwd-reqs .req-item{ display:flex; align-items:center; gap:6px; color:#94a3b8; padding:2px 0; transition:.2s; }
.pwd-reqs .req-item.met{ color:var(--ok); }
.pwd-reqs .req-item i{ width:14px; font-size:.7rem; }

.strength-bar{ height:5px; border-radius:4px; background:var(--border); margin-top:8px; overflow:hidden; }
.strength-fill{ height:100%; width:0%; transition:.3s; border-radius:4px; }
.strength-label{ font-size:.75rem; font-weight:700; margin-top:4px; }

.match-msg{ font-size:.78rem; margin-top:4px; display:flex; align-items:center; gap:6px; }
.match-msg.ok{ color:var(--ok); }
.match-msg.bad{ color:var(--danger); }

/* Vehicle type radio cards */
.vt-row{ display:flex; gap:12px; }
.vt-card{
    flex:1; border:1.5px solid var(--border); border-radius:14px; padding:16px;
    text-align:center; cursor:pointer; transition:.2s; background:#fff;
}
.vt-card:hover{ border-color:#cbd5e1; }
.vt-card.selected{ border-color:var(--accent); background:#eff8ff; box-shadow:0 0 0 4px rgba(30,144,255,.08); }
.vt-card .vt-ic{ font-size:1.8rem; margin-bottom:6px; }
.vt-card input{ display:none; }

/* Checkboxes */
.chk-row{ display:flex; align-items:flex-start; gap:10px; margin-bottom:10px; font-size:.85rem; color:var(--text-muted); }
.chk-row input{ accent-color:var(--accent); width:16px; height:16px; margin-top:2px; flex-shrink:0; }
.chk-row a{ color:var(--accent); font-weight:600; text-decoration:none; }

.btn-create{
    width:100%; background:var(--accent); color:#fff; border:none; border-radius:12px;
    padding:15px; font-weight:700; font-size:.97rem; cursor:pointer; transition:.2s;
    display:flex; align-items:center; justify-content:center; gap:8px; margin-top:8px;
}
.btn-create:hover:not(:disabled){ background:var(--accent-dark); transform:translateY(-1px); box-shadow:0 8px 20px rgba(30,144,255,.3); }
.btn-create:disabled{ opacity:.55; cursor:not-allowed; transform:none; }
.spinner{ width:16px; height:16px; border:2.5px solid rgba(255,255,255,.4); border-top-color:#fff; border-radius:50%; animation:spin .7s linear infinite; display:none; }
@@keyframes spin{ to{transform:rotate(360deg);} }

.divider{ display:flex; align-items:center; gap:12px; margin:26px 0 18px; color:#94a3b8; font-size:.8rem; }
.divider::before,.divider::after{ content:''; flex:1; height:1px; background:var(--border); }
.social-row{ display:flex; gap:10px; }
.social-btn{
    flex:1; display:flex; align-items:center; justify-content:center; gap:8px;
    padding:11px; border:1.5px solid var(--border); border-radius:12px;
    background:#fff; font-weight:600; font-size:.82rem; color:var(--navy);
    cursor:pointer; transition:.2s; text-decoration:none;
}
.social-btn:hover{ border-color:#cbd5e1; transform:translateY(-1px); }

.bottom-link{ text-align:center; margin-top:22px; font-size:.88rem; color:var(--text-muted); }
.bottom-link a{ color:var(--accent); font-weight:700; text-decoration:none; }

.alert-top{
    border-radius:12px; padding:12px 16px; margin-bottom:18px; font-size:.85rem;
    display:flex; align-items:center; gap:8px;
}
.alert-top.danger{ background:#fef2f2; color:#b91c1c; border:1px solid #fecaca; }

@@media (max-width:900px){
    .auth-left{ display:none; }
    .auth-right{ padding:24px 16px; }
    .signup-card{ padding:28px 22px; }
}
</style>
</head>
<body>
<div class="auth-wrap">

    <!-- LEFT -->
    <div class="auth-left">
        <div class="brand">Wash<span>N</span>Go <span class="badge-n">🚗</span></div>
        <div class="illu-zone">
            <svg class="car-illu" viewBox="0 0 500 320" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="250" cy="290" rx="170" ry="16" fill="#000" opacity=".25"/>
                <path d="M70 210 Q90 130 180 120 L320 120 Q400 130 430 210 L430 240 Q430 255 415 255 L85 255 Q70 255 70 240 Z" fill="#1E90FF"/>
                <path d="M150 125 Q180 90 250 90 Q320 90 350 125 L335 150 L165 150 Z" fill="#7fc4ff"/>
                <circle cx="150" cy="255" r="30" fill="#0d1b2a"/><circle cx="150" cy="255" r="13" fill="#cfd8e3"/>
                <circle cx="350" cy="255" r="30" fill="#0d1b2a"/><circle cx="350" cy="255" r="13" fill="#cfd8e3"/>
                <rect x="95" y="195" width="310" height="13" rx="6" fill="#fff" opacity=".35"/>
            </svg>
        </div>
        <div class="slogan-zone">
            <h1>Join WashNGo, drive <span>spotless</span></h1>
            <p>Create your account and book your first wash in seconds.</p>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="signup-card">
            <div class="sc-header">
                <h2>Create Your Account</h2>
                <p>Join WashNGo and book your next wash in seconds.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-top danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>Please fix the errors below and try again.</span>
                </div>
            }

            <form asp-action="Register" method="post" id="regForm" novalidate>
                @Html.AntiForgeryToken()

                <!-- PERSONAL INFO -->
                <div class="section-block">
                    <div class="section-title">Personal Information</div>

                    <div class="f-group">
                        <label class="f-label">Full Name <span class="req">*</span></label>
                        <input asp-for="FullName" class="f-input" placeholder="John Doe"/>
                        <span asp-validation-for="FullName" class="err-msg"></span>
                    </div>

                    <div class="row2">
                        <div class="f-group">
                            <label class="f-label">Username <span class="req">*</span></label>
                            <input asp-for="Username" class="f-input" placeholder="john_doe"/>
                            <span asp-validation-for="Username" class="err-msg"></span>
                        </div>
                        <div class="f-group">
                            <label class="f-label">Email Address <span class="req">*</span></label>
                            <input asp-for="Email" class="f-input" placeholder="you@example.com"/>
                            <span asp-validation-for="Email" class="err-msg"></span>
                        </div>
                    </div>

                    <div class="row2">
                        <div class="f-group">
                            <label class="f-label">Phone Number <span class="req">*</span></label>
                            <input asp-for="PhoneNumber" class="f-input" placeholder="+8801700000000"/>
                            <span asp-validation-for="PhoneNumber" class="err-msg"></span>
                        </div>
                        <div class="f-group">
                            <label class="f-label">Date of Birth (optional)</label>
                            <input asp-for="DateOfBirth" type="date" class="f-input"/>
                        </div>
                    </div>
                </div>

                <!-- SECURITY -->
                <div class="section-block">
                    <div class="section-title">Security</div>

                    <div class="f-group">
                        <label class="f-label">Password <span class="req">*</span></label>
                        <div class="f-input-wrap">
                            <input asp-for="Password" id="pwd" class="f-input" placeholder="Create a strong password" style="padding-right:42px;" oninput="checkPwd()"/>
                            <button type="button" class="toggle-eye" onclick="toggleEye('pwd','eye1')"><i class="fas fa-eye" id="eye1"></i></button>
                        </div>
                        <span asp-validation-for="Password" class="err-msg"></span>

                        <div class="strength-bar"><div class="strength-fill" id="strFill"></div></div>
                        <div class="strength-label" id="strLabel" style="color:#94a3b8;">Password strength</div>

                        <div class="pwd-reqs">
                            <div class="req-item" id="r-len"><i class="fas fa-circle"></i> Minimum 8 characters</div>
                            <div class="req-item" id="r-upper"><i class="fas fa-circle"></i> At least one uppercase letter (A-Z)</div>
                            <div class="req-item" id="r-lower"><i class="fas fa-circle"></i> At least one lowercase letter (a-z)</div>
                            <div class="req-item" id="r-num"><i class="fas fa-circle"></i> At least one number (0-9)</div>
                            <div class="req-item" id="r-special"><i class="fas fa-circle"></i> At least one special character (!@@#$%^&amp;*)</div>
                        </div>
                    </div>

                    <div class="f-group">
                        <label class="f-label">Confirm Password <span class="req">*</span></label>
                        <div class="f-input-wrap">
                            <input asp-for="ConfirmPassword" id="cpwd" class="f-input" placeholder="Repeat your password" style="padding-right:42px;" oninput="checkMatch()"/>
                            <button type="button" class="toggle-eye" onclick="toggleEye('cpwd','eye2')"><i class="fas fa-eye" id="eye2"></i></button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="err-msg"></span>
                        <div class="match-msg" id="matchMsg"></div>
                    </div>
                </div>

                <!-- CONTACT INFO -->
                <div class="section-block">
                    <div class="section-title">Contact Information</div>
                    <div class="row3">
                        <div class="f-group">
                            <label class="f-label">Division</label>
                            <input asp-for="Division" class="f-input" placeholder="Chattogram"/>
                        </div>
                        <div class="f-group">
                            <label class="f-label">City</label>
                            <input asp-for="City" class="f-input" placeholder="Chattogram"/>
                        </div>
                        <div class="f-group">
                            <label class="f-label">Area</label>
                            <input asp-for="Area" class="f-input" placeholder="Agrabad"/>
                        </div>
                    </div>
                    <div class="f-group">
                        <label class="f-label">Full Address <span class="req">*</span></label>
                        <input asp-for="Address" class="f-input" placeholder="House, Road, Area, City"/>
                        <span asp-validation-for="Address" class="err-msg"></span>
                    </div>
                </div>

                <!-- VEHICLE INFO -->
                <div class="section-block">
                    <div class="section-title">Vehicle Information</div>

                    <div class="f-group">
                        <label class="f-label">Vehicle Type <span class="req">*</span></label>
                        <div class="vt-row">
                            @{ var isCar = Model.VehicleType == "Car"; }
                            @{ var isBike = Model.VehicleType == "Bike"; }
                            <label class="vt-card @(isCar ? "selected" : "")" id="vtCar" onclick="selectVT('Car')">
                                @if (isCar)
                                {
                                    <input type="radio" name="VehicleType" value="Car" checked/>
                                }
                                else
                                {
                                    <input type="radio" name="VehicleType" value="Car"/>
                                }
                                <div class="vt-ic">🚗</div><div style="font-weight:600;font-size:.88rem;">Car</div>
                            </label>
                            <label class="vt-card @(isBike ? "selected" : "")" id="vtBike" onclick="selectVT('Bike')">
                                @if (isBike)
                                {
                                    <input type="radio" name="VehicleType" value="Bike" checked/>
                                }
                                else
                                {
                                    <input type="radio" name="VehicleType" value="Bike"/>
                                }
                                <div class="vt-ic">🏍️</div><div style="font-weight:600;font-size:.88rem;">Bike</div>
                            </label>
                        </div>
                        <span asp-validation-for="VehicleType" class="err-msg"></span>
                    </div>

                    <div class="row2">
                        <div class="f-group">
                            <label class="f-label">Vehicle Brand <span class="req">*</span></label>
                            <input asp-for="VehicleBrand" class="f-input" placeholder="Toyota, Honda, BMW, Yamaha"/>
                            <span asp-validation-for="VehicleBrand" class="err-msg"></span>
                        </div>
                        <div class="f-group">
                            <label class="f-label">Vehicle Model <span class="req">*</span></label>
                            <input asp-for="VehicleModel" class="f-input" placeholder="e.g. Corolla, CBR150"/>
                            <span asp-validation-for="VehicleModel" class="err-msg"></span>
                        </div>
                    </div>
                    <div class="f-group">
                        <label class="f-label">Vehicle Registration Number (optional)</label>
                        <input asp-for="VehicleRegNumber" class="f-input" placeholder="Dhaka Metro-Ga-11-1234"/>
                    </div>
                </div>

                <!-- PREFERENCES -->
                <div class="section-block">
                    <div class="section-title">Preferences</div>

                    <div class="f-group">
                        <label class="f-label">Preferred Language</label>
                        <select asp-for="PreferredLanguage" class="f-select">
                            <option value="English">English</option>
                            <option value="Bengali">বাংলা (Bengali)</option>
                        </select>
                    </div>

                    <label class="f-label" style="margin-bottom:8px;">Receive notifications by:</label>
                    <div class="chk-row"><input asp-for="NotifyByEmail" type="checkbox"/> Email</div>
                    <div class="chk-row"><input asp-for="NotifyBySms" type="checkbox"/> SMS</div>
                    <div class="chk-row"><input asp-for="NotifyByWhatsApp" type="checkbox"/> WhatsApp</div>
                </div>

                <!-- TERMS -->
                <div class="section-block">
                    <div class="section-title">Terms</div>
                    <div class="chk-row">
                        <input asp-for="AgreedToTerms" type="checkbox" id="termsChk"/>
                        <span>I agree to the <a href="#">Terms and Conditions</a> <span class="req">*</span></span>
                    </div>
                    <span asp-validation-for="AgreedToTerms" class="err-msg"></span>
                    <div class="chk-row">
                        <input asp-for="AgreedToPrivacyPolicy" type="checkbox" id="privacyChk"/>
                        <span>I agree to the <a href="#">Privacy Policy</a> <span class="req">*</span></span>
                    </div>
                    <span asp-validation-for="AgreedToPrivacyPolicy" class="err-msg"></span>
                    <div class="chk-row">
                        <input asp-for="OptInPromotions" type="checkbox"/>
                        <span>Receive promotional offers and discounts (optional)</span>
                    </div>
                </div>

                <button type="submit" class="btn-create" id="createBtn">
                    <span class="spinner" id="spinner"></span>
                    <span id="btnText">Create Account</span>
                </button>
            </form>

            <div class="divider">Or continue with</div>
            <div class="social-row">
                <a asp-action="ExternalLogin" asp-controller="Account" asp-route-provider="Google" class="social-btn">
                    <svg width="16" height="16" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3c-1.6 4.6-6 8-11.3 8-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 5.1 29.6 3 24 3 12.4 3 3 12.4 3 24s9.4 21 21 21 21-9.4 21-21c0-1.2-.1-2.4-.4-3.5z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 16 18.9 13 24 13c3.1 0 5.8 1.1 8 3l5.7-5.7C34.6 5.1 29.6 3 24 3 16.3 3 9.7 7.4 6.3 14.7z"/><path fill="#4CAF50" d="M24 45c5.5 0 10.4-1.9 13.9-5.1l-6.4-5.4C29.4 36.5 26.8 37.5 24 37.5c-5.2 0-9.6-3.3-11.2-7.9l-6.6 5.1C9.6 40.5 16.2 45 24 45z"/><path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.3-4.2 5.7l6.4 5.4C40.9 36.3 44 30.7 44 24c0-1.2-.1-2.4-.4-3.5z"/></svg>
                    Google
                </a>
                <a href="#" class="social-btn" style="opacity:.55;cursor:not-allowed;" onclick="alert('Apple Sign-In is coming soon!'); return false;" title="Coming soon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.142-1.64 3.248-1.68.03.13.05.28.05.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.07-2.383 1.4-2.383 4.05 0 2.99 2.514 4.073 2.954 4.583z"/></svg>
                    Apple
                </a>
                <a asp-action="ExternalLogin" asp-controller="Account" asp-route-provider="Facebook" class="social-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="#1877F2"><path d="M22 12c0-5.5-4.5-10-10-10S2 6.5 2 12c0 5 3.7 9.1 8.4 9.9v-7H7.9v-2.9h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6v1.9h2.8l-.4 2.9h-2.4v7C18.3 21.1 22 17 22 12z"/></svg>
                    Facebook
                </a>
            </div>

            <div class="bottom-link">
                Already have an account? <a asp-action="Login">Sign In</a>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_ValidationScriptsPartial")
<script>
if (typeof jQuery !== 'undefined' && typeof jQuery.validator !== 'undefined') {
    var defaultRange = jQuery.validator.methods.range;
    jQuery.validator.methods.range = function(value, element, param) {
        if (element.type === 'checkbox') {
            return element.checked;
        }
        return defaultRange.call(this, value, element, param);
    };
}

function toggleEye(inputId, iconId){
    const inp = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    inp.type = inp.type === 'password' ? 'text' : 'password';
    icon.classList.toggle('fa-eye'); icon.classList.toggle('fa-eye-slash');
}

function selectVT(type){
    document.getElementById('vtCar').classList.toggle('selected', type === 'Car');
    document.getElementById('vtBike').classList.toggle('selected', type === 'Bike');
    document.querySelector(`input[name="VehicleType"][value="${type}"]`).checked = true;
}

function checkPwd(){
    const v = document.getElementById('pwd').value;
    const checks = {
        len:     v.length >= 8,
        upper:   /[A-Z]/.test(v),
        lower:   /[a-z]/.test(v),
        num:     /\d/.test(v),
        special: /[!@@#$%^&*]/.test(v)
    };
    setReq('r-len', checks.len);
    setReq('r-upper', checks.upper);
    setReq('r-lower', checks.lower);
    setReq('r-num', checks.num);
    setReq('r-special', checks.special);

    const score = Object.values(checks).filter(Boolean).length;
    const fill = document.getElementById('strFill');
    const label = document.getElementById('strLabel');
    if (!v.length){ fill.style.width='0%'; label.textContent='Password strength'; label.style.color='#94a3b8'; }
    else if (score <= 2){ fill.style.width='33%'; fill.style.background='#ef4444'; label.textContent='Weak'; label.style.color='#ef4444'; }
    else if (score <= 4){ fill.style.width='66%'; fill.style.background='#f59e0b'; label.textContent='Medium'; label.style.color='#f59e0b'; }
    else { fill.style.width='100%'; fill.style.background='#22c55e'; label.textContent='Strong'; label.style.color='#22c55e'; }

    checkMatch();
}

function setReq(id, met){
    const el = document.getElementById(id);
    el.classList.toggle('met', met);
    el.querySelector('i').className = met ? 'fas fa-check-circle' : 'fas fa-circle';
}

function checkMatch(){
    const p = document.getElementById('pwd').value;
    const c = document.getElementById('cpwd').value;
    const msg = document.getElementById('matchMsg');
    if (!c.length){ msg.textContent=''; msg.className='match-msg'; return; }
    if (p === c){ msg.textContent='✔ Passwords match'; msg.className='match-msg ok'; }
    else { msg.textContent='✖ Passwords do not match'; msg.className='match-msg bad'; }
}

document.getElementById('regForm').addEventListener('submit', function(e){
    if (typeof jQuery !== 'undefined' && typeof jQuery.validator !== 'undefined') {
        if (!$(this).valid()) {
            return;
        }
    }
    const btn = document.getElementById('createBtn');
    document.getElementById('spinner').style.display = 'inline-block';
    document.getElementById('btnText').textContent = 'Creating account...';
    btn.disabled = true;
});
</script>
</body>
</html>
