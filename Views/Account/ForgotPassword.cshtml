@model WashNGo.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section style="background:var(--light-gray);min-height:calc(100vh - 72px);" class="d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="form-card">
                    <div class="text-center mb-4">
                        <div style="font-size:3rem;">🔑</div>
                        <h2 class="fw-bold mt-2 mb-1">Forgot Password?</h2>
                        <p class="text-muted" style="font-size:.93rem;">
                            Enter your email address and we'll send you a link to reset your password.
                        </p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus/>
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn-primary-custom w-100 justify-content-center py-3">
                            <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                        </button>
                    </form>

                    <hr class="my-4"/>
                    <p class="text-center text-muted mb-0" style="font-size:.93rem;">
                        Remember your password?
                        <a asp-action="Login" class="fw-bold text-primary">Sign in</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
