@model WashNGo.Models.User
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section style="background:var(--light-gray);min-height:calc(100vh - 72px);" class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <!-- Profile Header -->
                <div class="form-card mb-4 text-center">
                    <div class="mx-auto mb-3 d-flex align-items-center justify-content-center fw-bold text-white"
                         style="width:80px;height:80px;border-radius:50%;background:var(--primary);font-size:2rem;">
                        @Model.Username.Substring(0,1).ToUpper()
                    </div>
                    <h4 class="fw-bold mb-1">@Model.Username</h4>
                    <p class="text-muted mb-1">@Model.Email</p>
                    <span class="status-badge @(Model.AccountStatus == "Active" ? "status-confirmed" : "status-cancelled")">
                        @Model.AccountStatus
                    </span>
                    <div class="row g-3 mt-3 text-start">
                        <div class="col-md-6">
                            <small class="text-muted d-block">Member Since</small>
                            <span class="fw-semibold">@Model.RegistrationDate.ToString("dd MMMM yyyy")</span>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted d-block">Last Login</small>
                            <span class="fw-semibold">@(Model.LastLogin?.ToString("dd MMM yyyy, HH:mm") ?? "–")</span>
                        </div>
                    </div>
                </div>

                <!-- Edit Form -->
                <div class="form-card">
                    <h5 class="fw-bold mb-4">Update Profile</h5>
                    <form asp-action="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input class="form-control" value="@Model.Username" readonly style="background:#f8fafc;"/>
                            <small class="text-muted">Username cannot be changed.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" value="@Model.Email" readonly style="background:#f8fafc;"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" required/>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Address</label>
                            <input type="text" name="Address" class="form-control" value="@Model.Address" required/>
                        </div>
                        <button type="submit" class="btn-primary-custom w-100 justify-content-center py-3">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                    </form>
                </div>

                <div class="text-center mt-3">
                    <a asp-controller="Booking" asp-action="MyBookings" class="text-primary fw-semibold">
                        <i class="fas fa-calendar-alt me-1"></i>View My Bookings
                    </a>
                </div>

            </div>
        </div>
    </div>
</section>
