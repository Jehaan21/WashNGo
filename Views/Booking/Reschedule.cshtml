@model WashNGo.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Reschedule Booking";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bookingId = ViewBag.BookingID;
}

<section style="background:var(--light-gray);" class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="form-card">
                    <div class="mb-4">
                        <a asp-controller="Booking" asp-action="MyBookings" class="text-muted text-decoration-none">
                            <i class="fas fa-arrow-left me-2"></i>Back to My Bookings
                        </a>
                    </div>
                    <h4 class="fw-bold mb-1">Reschedule Booking</h4>
                    <p class="text-muted mb-4">Select a new date and time slot for your appointment.</p>

                    <form asp-action="Reschedule" asp-route-id="@bookingId" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label asp-for="BookingDate" class="form-label">New Booking Date</label>
                            <input asp-for="BookingDate" type="date" class="form-control" id="BookingDate"/>
                            <span asp-validation-for="BookingDate" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">New Time Slot</label>
                            <input type="hidden" asp-for="SlotID" id="SlotID"/>
                            <div class="row g-2" id="slotsGrid">
                                <p class="text-muted">Select a date to view available slots.</p>
                            </div>
                            <div id="noSlotsMsg" class="alert alert-danger d-none mb-2" style="border-radius:12px;"></div>
                            <span asp-validation-for="SlotID" class="text-danger small d-block mt-2"></span>
                        </div>

                        <button type="submit" class="btn-primary-custom w-100 justify-content-center py-3">
                            <i class="fas fa-calendar-check me-2"></i>Confirm Reschedule
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
