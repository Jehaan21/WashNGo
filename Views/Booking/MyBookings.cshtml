@model IEnumerable<WashNGo.Models.Booking>
@{
    ViewData["Title"] = "My Bookings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section style="background:var(--light-gray);" class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">My Bookings</h2>
                <p class="text-muted mb-0">Track, reschedule or cancel your wash appointments.</p>
            </div>
            <a asp-action="Create" class="btn-primary-custom">
                <i class="fas fa-plus me-2"></i>New Booking
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 form-card">
                <div style="font-size:4rem;">📋</div>
                <h4 class="mt-3 fw-bold">No Bookings Yet</h4>
                <p class="text-muted">You haven't made any bookings. Book your first wash now!</p>
                <a asp-action="Create" class="btn-primary-custom mt-3">Book a Wash</a>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var b in Model)
                {
                    <div class="form-card">
                        <div class="row align-items-center g-3">
                            <div class="col-md-1 text-center">
                                <div style="font-size:2.5rem;">@(b.VehicleType == "Bike" ? "🏍️" : "🚗")</div>
                            </div>
                            <div class="col-md-4">
                                <div class="fw-bold fs-5">@b.Service?.ServiceName</div>
                                <div class="text-muted" style="font-size:.9rem;">
                                    <i class="fas fa-hashtag me-1"></i>@(b.ReservationID ?? $"WNG-{b.BookingID:D6}")
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div><i class="fas fa-calendar me-2 text-primary"></i>@b.BookingDate.ToString("dd MMM yyyy")</div>
                                <div class="text-muted" style="font-size:.9rem;">
                                    <i class="fas fa-clock me-2"></i>@b.Slot?.SlotLabel
                                </div>
                            </div>
                            <div class="col-md-2">
                                <span class="status-badge status-@b.BookingStatus.ToLower().Replace(" ", "-")">
                                    @b.BookingStatus
                                </span>
                                <div class="text-primary fw-bold mt-1">৳@b.TotalAmount.ToString("N0")</div>
                            </div>
                            <div class="col-md-2 text-end">
                                <div class="d-flex gap-2 flex-wrap justify-content-end">
                                    @if (b.BookingStatus is "Pending" or "Confirmed")
                                    {
                                        <a asp-action="Reschedule" asp-route-id="@b.BookingID"
                                           class="btn btn-sm btn-outline-primary rounded-pill">Reschedule</a>
                                        <form asp-action="Cancel" asp-route-id="@b.BookingID" method="post" class="m-0"
                                              onsubmit="return confirm('Cancel this booking?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">Cancel</button>
                                        </form>
                                    }
                                    @if (b.BookingStatus == "Completed" && b.Review == null)
                                    {
                                        <a asp-controller="Review" asp-action="Create" asp-route-bookingId="@b.BookingID"
                                           class="btn btn-sm btn-outline-warning rounded-pill">
                                            ⭐ Review
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
