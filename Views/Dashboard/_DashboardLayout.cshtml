<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] – WashNGo Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
    @* Antiforgery token for AJAX POST requests *@
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    @{ var token = Antiforgery.GetAndStoreTokens(Context).RequestToken; }
    <meta name="csrf-token" content="@token"/>
</head>
<body>

<!-- ── Sidebar ────────────────────────────────────────────── -->
<aside class="dashboard-sidebar">
    <div class="sidebar-logo">Wash<span>N</span>Go</div>
    <nav class="sidebar-nav">
        <div class="sidebar-section">Overview</div>
        <a asp-controller="Dashboard" asp-action="Index"
           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>

        <div class="sidebar-section mt-3">Manage</div>
        <a asp-controller="Dashboard" asp-action="Services"
           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Service") == true ? "active" : "")">
            <i class="fas fa-spray-can"></i> Services
        </a>
        <a asp-controller="Dashboard" asp-action="TimeSlots"
           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "TimeSlots" ? "active" : "")">
            <i class="fas fa-clock"></i> Time Slots
        </a>
        <a asp-controller="Dashboard" asp-action="Bookings"
           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Bookings" ? "active" : "")">
            <i class="fas fa-calendar-alt"></i> Bookings
        </a>
        <a asp-controller="Dashboard" asp-action="Customers"
           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Customers" ? "active" : "")">
            <i class="fas fa-users"></i> Customers
        </a>
        <a asp-controller="Dashboard" asp-action="Reviews"
           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Reviews" ? "active" : "")">
            <i class="fas fa-star"></i> Reviews
        </a>
        <a asp-controller="Dashboard" asp-action="Messages"
           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Messages" ? "active" : "")">
            <i class="fas fa-envelope"></i> Messages
        </a>

        <div class="sidebar-section mt-3">Site</div>
        <a asp-controller="Home" asp-action="Index" class="sidebar-link">
            <i class="fas fa-globe"></i> View Site
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
            @Html.AntiForgeryToken()
            <button type="submit" class="sidebar-link w-100 border-0 text-start" style="background:none;">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </nav>
</aside>

<!-- ── Main ───────────────────────────────────────────────── -->
<div class="dashboard-main">
    <div class="dashboard-topbar">
        <div class="d-flex align-items-center gap-3">
            <button id="sidebarToggle" class="btn btn-sm btn-outline-secondary d-lg-none">
                <i class="fas fa-bars"></i>
            </button>
            <h6 class="mb-0 fw-bold">@ViewData["Title"]</h6>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted" style="font-size:.88rem;">@DateTime.Now.ToString("ddd, dd MMM yyyy")</span>
            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                 style="width:36px;height:36px;background:var(--primary);font-size:.9rem;">
                @User.Identity?.Name?.Substring(0,1).ToUpper()
            </div>
        </div>
    </div>

    <div class="dashboard-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-auto-dismiss alert-dismissible d-flex align-items-center gap-2 mb-4">
                <i class="fas fa-check-circle"></i><span>@TempData["Success"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-auto-dismiss alert-dismissible d-flex align-items-center gap-2 mb-4">
                <i class="fas fa-exclamation-circle"></i><span>@TempData["Error"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
