@model WashNGo.ViewModels.AnalyticsViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Dashboard/_DashboardLayout.cshtml";
}

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background:#dbeafe;">
                <i class="fas fa-users" style="color:#1d4ed8;"></i>
            </div>
            <div>
                <div class="stat-card-value">@Model.TotalUsers</div>
                <div class="stat-card-label">Total Customers</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background:#dcfce7;">
                <i class="fas fa-calendar-check" style="color:#15803d;"></i>
            </div>
            <div>
                <div class="stat-card-value">@Model.TotalBookings</div>
                <div class="stat-card-label">Total Bookings</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background:#fef9c3;">
                <i class="fas fa-clock" style="color:#a16207;"></i>
            </div>
            <div>
                <div class="stat-card-value">@Model.PendingBookings</div>
                <div class="stat-card-label">Pending Bookings</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background:#dcfce7;">
                <i class="fas fa-money-bill-wave" style="color:#15803d;"></i>
            </div>
            <div>
                <div class="stat-card-value">৳@Model.TotalRevenue.ToString("N0")</div>
                <div class="stat-card-label">Total Revenue</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background:#fce7f3;">
                <i class="fas fa-calendar-day" style="color:#be185d;"></i>
            </div>
            <div>
                <div class="stat-card-value">@Model.TodaysBookings</div>
                <div class="stat-card-label">Today's Bookings</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-icon" style="background:#fee2e2;">
                <i class="fas fa-envelope" style="color:#b91c1c;"></i>
            </div>
            <div>
                <div class="stat-card-value">@Model.UnreadMessages</div>
                <div class="stat-card-label">Unread Messages</div>
            </div>
        </div>
    </div>
</div>

<!-- Tables -->
<div class="row g-4">
    <!-- Popular Services -->
    <div class="col-lg-6">
        <div class="bg-white rounded-3 shadow-sm border p-4">
            <h6 class="fw-bold mb-3">🔥 Popular Services</h6>
            @if (!Model.PopularServices.Any())
            {
                <p class="text-muted">No data yet.</p>
            }
            else
            {
                @foreach (var (name, count) in Model.PopularServices)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-semibold" style="font-size:.93rem;">@name</span>
                        <div class="d-flex align-items-center gap-2">
                            <div style="width:120px;height:8px;background:var(--light-gray);border-radius:4px;">
                                <div style="width:@(count * 10)%;max-width:100%;height:100%;background:var(--primary);border-radius:4px;"></div>
                            </div>
                            <span class="text-muted" style="font-size:.85rem;width:40px;text-align:right;">@count</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Bookings by Status -->
    <div class="col-lg-6">
        <div class="bg-white rounded-3 shadow-sm border p-4">
            <h6 class="fw-bold mb-3">📊 Bookings by Status</h6>
            @if (!Model.BookingsByStatus.Any())
            {
                <p class="text-muted">No bookings yet.</p>
            }
            else
            {
                @foreach (var (status, count) in Model.BookingsByStatus)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="status-badge status-@status.ToLower().Replace(" ", "-")">@status</span>
                        <span class="fw-bold">@count</span>
                    </div>
                }
            }
        </div>
    </div>
</div>
