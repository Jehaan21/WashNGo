@* ── Dashboard/Messages.cshtml ── *@
@model IEnumerable<WashNGo.Models.ContactMessage>
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Dashboard/_DashboardLayout.cshtml";
}

<h5 class="fw-bold mb-4">Contact Messages</h5>

<div class="d-flex flex-column gap-3">
    @if (!Model.Any())
    {
        <div class="bg-white rounded-3 p-5 text-center shadow-sm border">
            <div style="font-size:3rem;">📭</div>
            <h5 class="mt-3">No messages yet</h5>
            <p class="text-muted">Customer contact form submissions will appear here.</p>
        </div>
    }
    @foreach (var m in Model)
    {
        <div class="bg-white rounded-3 shadow-sm border p-4 @(m.IsRead ? "" : "border-primary")" style="@(m.IsRead ? "" : "border-width:2px!important;")">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                <div>
                    <span class="fw-bold">@m.Name</span>
                    <span class="text-muted ms-2" style="font-size:.88rem;">@m.Email</span>
                    @if (!m.IsRead)
                    {
                        <span class="badge bg-primary ms-2">New</span>
                    }
                </div>
                <small class="text-muted">@m.SentAt.ToString("dd MMM yyyy, HH:mm")</small>
            </div>
            <div class="fw-semibold mb-1">@m.Subject</div>
            <p class="text-muted mb-3" style="font-size:.93rem;">@m.Message</p>
            <div class="d-flex gap-2">
                @if (!m.IsRead)
                {
                    <form asp-action="MarkMessageRead" asp-route-id="@m.MessageID" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-3">Mark Read</button>
                    </form>
                }
                <a href="mailto:@m.Email?subject=Re: @m.Subject" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                    Reply via Email
                </a>
                <form asp-action="DeleteMessage" asp-route-id="@m.MessageID" method="post" class="m-0"
                      onsubmit="return confirm('Delete this message?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                </form>
            </div>
        </div>
    }
</div>
