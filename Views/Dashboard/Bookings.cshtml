@model IEnumerable<WashNGo.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
    Layout = "~/Views/Dashboard/_DashboardLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h5 class="fw-bold mb-0">All Bookings</h5>
    <form method="get" class="d-flex gap-2 flex-wrap">
        <select name="status" class="form-select form-select-sm" style="width:auto;">
            <option value="All">All Status</option>
            @foreach (var st in new[] {"Pending","Confirmed","In Progress","Completed","Cancelled"})
            {
                <option value="@st" selected="@(ViewBag.StatusFilter == st)">@st</option>
            }
        </select>
        <input type="date" name="date" class="form-control form-control-sm" style="width:auto;" value="@ViewBag.DateFilter"/>
        <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3">Filter</button>
    </form>
</div>

<div class="bg-white rounded-3 shadow-sm border overflow-hidden">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Reservation ID</th>
                <th>Customer</th>
                <th>Service</th>
                <th>Date / Slot</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No bookings found.</td></tr>
            }
            @foreach (var b in Model)
            {
                <tr>
                    <td class="fw-bold text-primary" style="font-family:monospace;">
                        @(b.ReservationID ?? $"WNG-{b.BookingID:D6}")
                    </td>
                    <td>
                        <div class="fw-semibold">@b.User?.Username</div>
                        <small class="text-muted">@b.User?.PhoneNumber</small>
                    </td>
                    <td>
                        <div>@b.Service?.ServiceName</div>
                        <small class="text-muted">@b.VehicleType</small>
                    </td>
                    <td>
                        <div>@b.BookingDate.ToString("dd MMM yyyy")</div>
                        <small class="text-muted">@b.Slot?.SlotLabel</small>
                    </td>
                    <td class="fw-bold text-primary">৳@b.TotalAmount.ToString("N0")</td>
                    <td>
                        <span class="status-badge status-@b.BookingStatus.ToLower().Replace(" ", "-")">
                            @b.BookingStatus
                        </span>
                    </td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            <a asp-action="BookingDetail" asp-route-id="@b.BookingID"
                               class="btn btn-xs btn-outline-secondary rounded-pill px-2 py-1" style="font-size:.78rem;">View</a>
                            @foreach (var st in new[] {"Confirmed","In Progress","Completed","Cancelled"})
                            {
                                if (b.BookingStatus != st)
                                {
                                    <form asp-action="UpdateBookingStatus" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@b.BookingID"/>
                                        <input type="hidden" name="status" value="@st"/>
                                        <button type="submit" class="btn btn-xs rounded-pill px-2 py-1"
                                                style="font-size:.75rem;border:1px solid var(--border);">
                                            @st
                                        </button>
                                    </form>
                                }
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
