@* ── Dashboard/Services.cshtml ── *@
@model IEnumerable<WashNGo.Models.Service>
@{
    ViewData["Title"] = "Services";
    Layout = "~/Views/Dashboard/_DashboardLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Manage Services</h5>
    <a asp-action="CreateService" class="btn-primary-custom btn-sm">
        <i class="fas fa-plus me-2"></i>Add Service
    </a>
</div>

<div class="bg-white rounded-3 shadow-sm border overflow-hidden">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Service</th>
                <th>Vehicle</th>
                <th>Price</th>
                <th>Duration</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td class="fw-semibold">@s.ServiceName</td>
                    <td><span class="service-badge badge-@s.VehicleType.ToLower()">@s.VehicleType</span></td>
                    <td class="text-primary fw-bold">৳@s.Price.ToString("N0")</td>
                    <td>@s.DurationMinutes min</td>
                    <td>
                        @if (s.IsAvailable)
                        {
                            <span class="status-badge status-confirmed">Active</span>
                        }
                        else
                        {
                            <span class="status-badge status-cancelled">Inactive</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-action="EditService" asp-route-id="@s.ServiceID"
                               class="btn btn-sm btn-outline-primary rounded-pill px-3">Edit</a>
                            <form asp-action="ToggleServiceAvailability" asp-route-id="@s.ServiceID" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                    @(s.IsAvailable ? "Deactivate" : "Activate")
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
