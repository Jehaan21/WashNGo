@* ── Dashboard/CreateService.cshtml ── *@
@model WashNGo.ViewModels.ServiceFormViewModel
@{
    ViewData["Title"] = "Add Service";
    Layout = "~/Views/Dashboard/_DashboardLayout.cshtml";
}

<div class="mb-4">
    <a asp-action="Services" class="text-muted text-decoration-none">
        <i class="fas fa-arrow-left me-2"></i>Back to Services
    </a>
</div>

<div class="bg-white rounded-3 shadow-sm border p-4" style="max-width:700px;">
    <h5 class="fw-bold mb-4">Add New Service</h5>

    <form asp-action="CreateService" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-12">
                <label asp-for="ServiceName" class="form-label">Service Name</label>
                <input asp-for="ServiceName" class="form-control" placeholder="e.g. Premium Car Wash"/>
                <span asp-validation-for="ServiceName" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe what's included…"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Price" class="form-label">Price (৳)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" placeholder="0.00"/>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DurationMinutes" class="form-label">Duration (minutes)</label>
                <input asp-for="DurationMinutes" class="form-control" type="number" min="1" placeholder="60"/>
                <span asp-validation-for="DurationMinutes" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="VehicleType" class="form-label">Vehicle Type</label>
                <select asp-for="VehicleType" class="form-select">
                    <option value="">-- Select --</option>
                    <option value="Bike">🏍️ Bike</option>
                    <option value="Car">🚗 Car</option>
                    <option value="Both">🚿 Both</option>
                </select>
                <span asp-validation-for="VehicleType" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="ImageFile" class="form-label">Service Image (optional)</label>
                <input asp-for="ImageFile" class="form-control" type="file" accept="image/*"/>
            </div>
            <div class="col-12">
                <div class="form-check form-switch">
                    <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked/>
                    <label asp-for="IsAvailable" class="form-check-label">Available for booking</label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-primary-custom">
                <i class="fas fa-plus me-2"></i>Create Service
            </button>
            <a asp-action="Services" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
